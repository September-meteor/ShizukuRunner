<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    >

    <Switch
        android:id="@+id/s"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/hide_from_recents"
        android:padding="16dp"/>

    <Switch
        android:id="@+id/s1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enable_50_commands"
        android:padding="16dp"/>

    <Switch
        android:id="@+id/lang_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/language_switch"
        android:padding="16dp"/>

    <!-- 多行命令模式开关（替代原来的实验性功能+切换按钮） -->
    <Switch
        android:id="@+id/multi_line_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/multi_line_mode"
        android:padding="10dp" />

    <Switch
        android:id="@+id/auto_wrap_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_wrap_experimental"
        android:padding="10dp"
        android:checked="true" />
</LinearLayout>